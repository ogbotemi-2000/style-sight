# Configuration file for Style Proxy Server

# Allowed domains (comma-separated, or '*' to allow all)
# ALLOWED_DOMAINS=example.com,example.org
ALLOWED_DOMAINS=*

# Server port
PORT=3000

# Require API key authentication for /proxy
AUTH_REQUIRED=false
PROXY_API_KEYS=

# Production-safe rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Enable/disable features (these are configured in server.js)
MODIFY_CSP=true
MODIFY_X_FRAME_OPTIONS=true
REWRITE_URLS=true
LOG_REQUESTS=true
